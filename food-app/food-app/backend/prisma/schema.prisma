generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(uuid())
  email     String   @unique
  name      String
  phone     String?
  password  String
  avatar    String?
  role      Role     @default(CUSTOMER)
  isBlocked Boolean  @default(false) @map("is_blocked")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  orders           Order[]        @relation("UserOrders")
  deliveries       Order[]        @relation("DriverOrders")
  transactions     Transaction[]
  reviews          Review[]
  wishlists        Wishlist[]
  store            Store?
  driverProfile    DriverProfile?
  sentMessages     ChatMessage[]  @relation("SentMessages")
  receivedMessages ChatMessage[]  @relation("ReceivedMessages")
  partnerRequests  PartnerRequest[]
  addresses        UserAddress[]

  @@map("users")
}

model UserAddress {
  id        String   @id @default(uuid())
  userId    String   @map("user_id")
  label     String   @default("Nhà")
  address   String
  lat       Float?
  lng       Float?
  isDefault Boolean  @default(false) @map("is_default")
  createdAt DateTime @default(now()) @map("created_at")

  user      User     @relation(fields: [userId], references: [id])

  @@map("user_addresses")
}

enum Role {
  CUSTOMER
  RESTAURANT
  ADMIN
  DRIVER
}

model Store {
  id          String   @id @default(uuid())
  name        String
  description String?
  image       String?
  coverImage  String?  @map("cover_image")
  address     String?
  phone       String?
  lat         Float?
  lng         Float?
  isOpen      Boolean  @default(true) @map("is_open")
  openTime    String?  @default("07:00") @map("open_time")
  closeTime   String?  @default("22:00") @map("close_time")
  rating      Float    @default(0)
  totalOrders Int      @default(0) @map("total_orders")
  tags        String[] @default([])
  ownerId     String   @unique @map("owner_id")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  owner    User      @relation(fields: [ownerId], references: [id])
  products Product[]
  orders   Order[]
  coupons  Coupon[]

  @@map("stores")
}

model Product {
  id           String   @id @default(uuid())
  name         String
  description  String?
  price        Float
  image        String?
  category     String
  isAvailable  Boolean  @default(true) @map("is_available")
  isSpicy      Boolean  @default(false) @map("is_spicy")
  isVegetarian Boolean  @default(false) @map("is_vegetarian")
  calories     Int?
  tags         String[] @default([])
  storeId      String?  @map("store_id")
  saleStartTime  String?   @map("sale_start_time")
  saleEndTime    String?   @map("sale_end_time")
  salePrice      Float?    @map("sale_price")
  flashSaleStart DateTime? @map("flash_sale_start")
  flashSaleEnd   DateTime? @map("flash_sale_end")
  options        Json?
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  store      Store?     @relation(fields: [storeId], references: [id])
  orderItems OrderItem[]
  reviews    Review[]
  wishlists  Wishlist[]

  @@map("products")
}

model Order {
  id              String      @id @default(uuid())
  userId          String      @map("user_id")
  storeId         String?     @map("store_id")
  driverId        String?     @map("driver_id")
  status          OrderStatus @default(PENDING)
  total           Float
  discount        Float       @default(0)
  shippingFee     Float       @default(15000) @map("shipping_fee")
  couponCode      String?     @map("coupon_code")
  note            String?
  deliveryAddress String?     @map("delivery_address")
  deliveryPhone   String?     @map("delivery_phone")
  deliveryLat     Float?      @map("delivery_lat")
  deliveryLng     Float?      @map("delivery_lng")
  rejectReason    String?     @map("reject_reason")
  storeRating     Int?        @map("store_rating")
  driverRating    Int?        @map("driver_rating")
  driverTip       Float       @default(0) @map("driver_tip")
  reviewComment   String?     @map("review_comment")
  reviewImage     String?     @map("review_image")
  paymentMethod   String?     @default("COD") @map("payment_method")
  scheduledAt     DateTime?   @map("scheduled_at")
  isScheduled     Boolean     @default(false) @map("is_scheduled")
  refundStatus    RefundStatus @default(NONE) @map("refund_status")
  refundedAt      DateTime?   @map("refunded_at")
  createdAt       DateTime    @default(now()) @map("created_at")
  updatedAt       DateTime    @updatedAt @map("updated_at")

  user         User           @relation("UserOrders", fields: [userId], references: [id])
  driver       User?          @relation("DriverOrders", fields: [driverId], references: [id])
  store        Store?         @relation(fields: [storeId], references: [id])
  items        OrderItem[]
  transactions Transaction[]
  history      OrderHistory[]
  chatMessages ChatMessage[]

  @@map("orders")
}

enum OrderStatus {
  PENDING
  CONFIRMED
  PREPARING
  PREPARED
  PICKING_UP
  DELIVERING
  DELIVERED
  CANCELLED
}

enum RefundStatus {
  NONE
  PENDING
  COMPLETED
}

model OrderItem {
  id              String @id @default(uuid())
  orderId         String @map("order_id")
  productId       String @map("product_id")
  quantity        Int
  price           Float
  selectedOptions Json?

  order   Order   @relation(fields: [orderId], references: [id])
  product Product @relation(fields: [productId], references: [id])

  @@map("order_items")
}

model Transaction {
  id             String            @id @default(uuid())
  orderId        String            @map("order_id")
  userId         String            @map("user_id")
  amount         Float
  method         String
  status         TransactionStatus @default(PENDING)
  idempotencyKey String            @unique @map("idempotency_key")
  createdAt      DateTime          @default(now()) @map("created_at")

  order Order @relation(fields: [orderId], references: [id])
  user  User  @relation(fields: [userId], references: [id])

  @@map("transactions")
}

enum TransactionStatus {
  PENDING
  SUCCESS
  FAILED
  REFUNDED
}

model OrderHistory {
  id        String      @id @default(uuid())
  orderId   String      @map("order_id")
  status    OrderStatus
  note      String?
  createdAt DateTime    @default(now()) @map("created_at")

  order Order @relation(fields: [orderId], references: [id])

  @@map("order_history")
}

model Review {
  id          String    @id @default(uuid())
  userId      String    @map("user_id")
  productId   String    @map("product_id")
  rating      Int
  comment     String
  sellerReply String?   @map("seller_reply")
  replyAt     DateTime? @map("reply_at")
  createdAt   DateTime  @default(now()) @map("created_at")

  user    User    @relation(fields: [userId], references: [id])
  product Product @relation(fields: [productId], references: [id])

  @@unique([userId, productId])
  @@map("reviews")
}

model Coupon {
  id            String    @id @default(uuid())
  code          String    @unique
  description   String?
  discountType  String    @default("PERCENT") @map("discount_type")
  discountValue Float     @map("discount_value")
  minOrderValue Float     @default(0) @map("min_order_value")
  maxDiscount   Float?    @map("max_discount")
  usageLimit    Int       @default(100) @map("usage_limit")
  usedCount     Int       @default(0) @map("used_count")
  isActive      Boolean   @default(true) @map("is_active")
  expiresAt     DateTime? @map("expires_at")
  storeId       String?   @map("store_id")
  createdAt     DateTime  @default(now()) @map("created_at")

  store Store? @relation(fields: [storeId], references: [id])

  @@map("coupons")
}

model Wishlist {
  id        String   @id @default(uuid())
  userId    String   @map("user_id")
  productId String   @map("product_id")
  createdAt DateTime @default(now()) @map("created_at")

  user    User    @relation(fields: [userId], references: [id])
  product Product @relation(fields: [productId], references: [id])

  @@unique([userId, productId])
  @@map("wishlists")
}

model ChatMessage {
  id         String   @id @default(uuid())
  orderId    String   @map("order_id")
  senderId   String   @map("sender_id")
  receiverId String   @map("receiver_id")
  content    String
  isRead     Boolean  @default(false) @map("is_read")
  createdAt  DateTime @default(now()) @map("created_at")

  order    Order @relation(fields: [orderId], references: [id])
  sender   User  @relation("SentMessages", fields: [senderId], references: [id])
  receiver User  @relation("ReceivedMessages", fields: [receiverId], references: [id])

  @@map("chat_messages")
}

model DriverProfile {
  id              String   @id @default(uuid())
  userId          String   @unique @map("user_id")
  vehicleType     String   @default("MOTORBIKE") @map("vehicle_type")
  vehiclePlate    String?  @map("vehicle_plate")
  idCardNumber    String?  @map("id_card_number")
  isOnline        Boolean  @default(false) @map("is_online")
  isVerified      Boolean  @default(false) @map("is_verified")
  currentLat      Float?   @map("current_lat")
  currentLng      Float?   @map("current_lng")
  totalDeliveries Int      @default(0) @map("total_deliveries")
  averageRating   Float    @default(5.0) @map("average_rating")
  totalEarnings   Float    @default(0) @map("total_earnings")
  acceptanceRate  Float    @default(100) @map("acceptance_rate")
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id])

  @@map("driver_profiles")
}

model DriverEarning {
  id        String   @id @default(uuid())
  driverId  String   @map("driver_id")
  orderId   String   @map("order_id")
  baseFee   Float    @map("base_fee")
  tip       Float    @default(0)
  bonus     Float    @default(0)
  totalFee  Float    @map("total_fee")
  createdAt DateTime @default(now()) @map("created_at")

  @@map("driver_earnings")
}

model PartnerRequest {
  id           String               @id @default(uuid())
  userId       String               @map("user_id")
  type         PartnerType
  status       PartnerRequestStatus @default(PENDING)
  
  // Fields for Seller
  storeName    String?              @map("store_name")
  storeAddress String?              @map("store_address")
  
  // Fields for Driver
  vehicleType  String?              @map("vehicle_type")
  vehiclePlate String?              @map("vehicle_plate")
  idCardNumber String?              @map("id_card_number")
  
  notes        String?
  createdAt    DateTime             @default(now()) @map("created_at")
  updatedAt    DateTime             @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id])

  @@map("partner_requests")
}

enum PartnerType {
  SELLER
  DRIVER
}

enum PartnerRequestStatus {
  PENDING
  APPROVED
  REJECTED
}

model PasswordReset {
  id        String   @id @default(uuid())
  email     String
  token     String   @unique
  expiresAt DateTime @map("expires_at")
  used      Boolean  @default(false)
  createdAt DateTime @default(now()) @map("created_at")

  @@map("password_resets")
}
